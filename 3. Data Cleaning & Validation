{"cells":[{"cell_type":"markdown","metadata":{"id":"c8iiSIYTeoat"},"source":["# ***Data Cleaning***"]},{"cell_type":"markdown","metadata":{"id":"6fEyDFudc4RB"},"source":["**Miêu tả:** Làm sạch dữ liệu trước khi đưa sang các bước tiếp theo như feature engineering, pseudo-labeling hoặc huấn luyện mô hình. Mục tiêu chính của pipeline là chuẩn hóa dữ liệu đầu vào, loại bỏ các dòng lỗi, xử lý dữ liệu trùng lặp, chia dữ liệu theo thời gian, xử lý outlier và điền missing values theo cách tránh rò rỉ dữ liệu. Code được thiết kế theo hướng cleaning only, tức là chỉ làm sạch dữ liệu, chưa tạo đặc trưng mới cho mô hình.\n","\n","Load raw data\n","\n","---------------↓---------------\n","\n","Phase 0: Schema Validation\n","\n","---------------↓---------------\n","\n","Phase A: Row-wise Cleaning\n","\n","---------------↓---------------\n","\n","Phase B: Train/Val/Test Split\n","\n","---------------↓---------------\n","\n","Phase C1: Outlier Handling\n","\n","---------------↓---------------\n","\n","Phase C2: Missing Value Handling\n","\n","---------------↓---------------\n","    \n","Save cleaned datasets + report"]},{"cell_type":"markdown","metadata":{"id":"dJRD8ZZzKUbg"},"source":["# **Import thư viện**"]},{"cell_type":"code","execution_count":20,"metadata":{"id":"9iBNAD6rKSdF","executionInfo":{"status":"ok","timestamp":1779903736928,"user_tz":-420,"elapsed":28,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["import json\n","import logging\n","import re\n","import unicodedata\n","from dataclasses import dataclass, field\n","from enum import Enum, auto\n","from pathlib import Path\n","from typing import Any, Optional\n","\n","import numpy as np\n","import pandas as pd\n","from __future__ import annotations"]},{"cell_type":"markdown","metadata":{"id":"Yzb0-8ZrKVBf"},"source":["# **Logging và hàm in thông tin**"]},{"cell_type":"code","execution_count":21,"metadata":{"id":"YRmTwOPpKVRV","executionInfo":{"status":"ok","timestamp":1779903736943,"user_tz":-420,"elapsed":12,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["def _build_logger(name: str = \"tiki_pipeline\", level: int = logging.INFO) -> logging.Logger:\n","    logging.basicConfig(\n","        level=level,\n","        format=\"%(asctime)s  [%(levelname)-8s]  %(name)s — %(message)s\",\n","        datefmt=\"%H:%M:%S\",\n","    )\n","    return logging.getLogger(name)\n","\n","\n","logger = _build_logger()\n","\n","\n","def _print_step(msg: str) -> None:\n","    print(f\"\\n{'='*60}\")\n","    print(f\"  STEP: {msg}\")\n","    print(f\"{'='*60}\")\n","\n","\n","def _print_stat(label: str, value: Any) -> None:\n","    print(f\"  [STAT] {label}: {value}\")"]},{"cell_type":"markdown","metadata":{"id":"Q7jpeEkGKVgj"},"source":["# **Enum và Config**"]},{"cell_type":"code","execution_count":22,"metadata":{"id":"A0ulIYcTKVro","executionInfo":{"status":"ok","timestamp":1779903736944,"user_tz":-420,"elapsed":9,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class OutlierMode(Enum):\n","    REMOVE = auto()\n","    CAP = auto()\n","\n","\n","class OutlierMethod(Enum):\n","    IQR = auto()\n","    PERCENTILE = auto()\n","    DOMAIN = auto()\n","\n","\n","class MissingMechanism(str, Enum):\n","    MCAR = \"MCAR\"\n","    MAR = \"MAR\"\n","    MNAR = \"MNAR\"\n","\n","@dataclass\n","class OutlierStrategyConfig:\n","    method: OutlierMethod = OutlierMethod.IQR\n","    iqr_multiplier: float = 1.5\n","    upper_pct: float = 0.99\n","    lower_pct: float = 0.00\n","    domain_min: Optional[float] = None\n","    domain_max: Optional[float] = None\n","\n","\n","@dataclass\n","class OutlierStrategyConfig:\n","    method: OutlierMethod = OutlierMethod.IQR\n","    iqr_multiplier: float = 1.5\n","    upper_pct: float = 0.99\n","    lower_pct: float = 0.00\n","    domain_min: Optional[float] = None\n","    domain_max: Optional[float] = None\n","\n","\n","@dataclass\n","class PipelineConfig:\n","    input_paths: list[Path] = field(default_factory=list)\n","    output_dir: Path = Path(\"outputs\")\n","\n","    train_ratio: float = 0.70\n","    val_ratio: float = 0.15\n","    test_ratio: float = 0.15\n","\n","    required_columns: list[str] = field(default_factory=lambda: [\n","        \"review_id\",\n","        \"rating\",\n","    ])\n","\n","    important_columns: list[str] = field(default_factory=lambda: [\n","        \"product_id\",\n","        \"customer_id\",\n","        \"content\",\n","        \"review_created_date\",\n","        \"num_vote_agree\",\n","        \"customer_total_review\",\n","        \"customer_total_thank\",\n","    ])\n","\n","    valid_ratings: frozenset[int] = field(\n","        default_factory=lambda: frozenset({1, 2, 3, 4, 5})\n","    )\n","\n","    outlier_mode: OutlierMode = OutlierMode.CAP\n","\n","    outlier_strategies: dict[str, OutlierStrategyConfig] = field(default_factory=lambda: {\n","        \"customer_total_review\": OutlierStrategyConfig(\n","            method=OutlierMethod.PERCENTILE,\n","            upper_pct=0.99,\n","        ),\n","        \"customer_total_thank\": OutlierStrategyConfig(\n","            method=OutlierMethod.PERCENTILE,\n","            upper_pct=0.99,\n","        ),\n","        \"num_vote_agree\": OutlierStrategyConfig(\n","            method=OutlierMethod.DOMAIN,\n","            domain_min=0.0,\n","            domain_max=None,\n","        ),\n","        \"num_images\": OutlierStrategyConfig(\n","            method=OutlierMethod.DOMAIN,\n","            domain_min=0.0,\n","            domain_max=10.0,\n","        ),\n","    })\n","\n","    mnar_miss_rate_threshold: float = 0.50\n","    mar_corr_threshold: float = 0.10\n","\n","    missing_mechanism_overrides: dict[str, MissingMechanism] = field(\n","        default_factory=lambda: {\n","            \"delivery_date\": MissingMechanism.MNAR,\n","            \"explain\": MissingMechanism.MNAR,\n","            \"customer_joined_time\": MissingMechanism.MNAR,\n","        }\n","    )\n","\n","    random_state: int = 42\n","\n","    def __post_init__(self) -> None:\n","        ratio_sum = self.train_ratio + self.val_ratio + self.test_ratio\n","\n","        if abs(ratio_sum - 1.0) > 1e-9:\n","            raise ValueError(\n","                f\"train + val + test ratio phải bằng 1.0, hiện = {ratio_sum:.8f}\"\n","            )\n"]},{"cell_type":"markdown","metadata":{"id":"32i5oWUVKV0V"},"source":["# **Data Quality Report**"]},{"cell_type":"code","execution_count":23,"metadata":{"id":"yiTWmT9hKWCT","executionInfo":{"status":"ok","timestamp":1779903736951,"user_tz":-420,"elapsed":12,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class DataQualityReport:\n","\n","    def __init__(self) -> None:\n","        self._data: dict[str, Any] = {\n","            \"phase_a\": {\n","                \"rows_at_start\": 0,\n","                \"header_rows_removed\": 0,\n","                \"duplicates_removed\": {},\n","                \"invalid_rating_removed\": 0,\n","                \"impossible_values_nullified\": {},\n","                \"explain_parsed_to_hours\": 0,\n","                \"joined_time_parsed_to_months\": 0,\n","            },\n","            \"phase_b\": {\n","                \"split_rows\": {},\n","            },\n","            \"phase_c\": {\n","                \"missing_per_column_before_impute\": {},\n","                \"missing_mechanisms\": {},\n","                \"outlier_mode\": \"\",\n","                \"outlier_bounds\": {},\n","                \"outlier_rows_affected\": {},\n","            },\n","        }\n","\n","    def record_start(self, rows: int) -> None:\n","        self._data[\"phase_a\"][\"rows_at_start\"] = rows\n","\n","    def record_header_removal(self, n: int) -> None:\n","        self._data[\"phase_a\"][\"header_rows_removed\"] = n\n","\n","    def record_dedup(self, rule: str, n_removed: int) -> None:\n","        self._data[\"phase_a\"][\"duplicates_removed\"][rule] = n_removed\n","\n","    def record_invalid_rating(self, n: int) -> None:\n","        self._data[\"phase_a\"][\"invalid_rating_removed\"] = n\n","\n","    def record_impossible_values(self, col: str, n: int) -> None:\n","        self._data[\"phase_a\"][\"impossible_values_nullified\"][col] = n\n","\n","    def record_explain_parsed(self, n: int) -> None:\n","        self._data[\"phase_a\"][\"explain_parsed_to_hours\"] = n\n","\n","    def record_joined_time_parsed(self, n: int) -> None:\n","        self._data[\"phase_a\"][\"joined_time_parsed_to_months\"] = n\n","\n","    def record_missing_critical_ids(self, col: str, n: int) -> None:\n","        key = f\"missing_{col}_removed\"\n","        self._data[\"phase_a\"][key] = n\n","\n","    def record_split(self, train: int, val: int, test: int) -> None:\n","        self._data[\"phase_b\"][\"split_rows\"] = {\n","            \"train\": train,\n","            \"val\": val,\n","            \"test\": test,\n","            \"total\": train + val + test,\n","        }\n","\n","    def record_missing_before_impute(self, col: str, n: int) -> None:\n","        self._data[\"phase_c\"][\"missing_per_column_before_impute\"][col] = n\n","\n","    def record_missing_mechanism(\n","        self,\n","        col: str,\n","        mechanism: MissingMechanism,\n","        fill_value: Any,\n","    ) -> None:\n","        self._data[\"phase_c\"][\"missing_mechanisms\"][col] = {\n","            \"mechanism\": mechanism.value,\n","            \"fill_value\": str(fill_value),\n","        }\n","\n","    def record_outlier_mode(self, mode: str) -> None:\n","        self._data[\"phase_c\"][\"outlier_mode\"] = mode\n","\n","    def record_outlier_bounds(\n","        self,\n","        col: str,\n","        method: str,\n","        lower: Optional[float],\n","        upper: Optional[float],\n","    ) -> None:\n","        self._data[\"phase_c\"][\"outlier_bounds\"][col] = {\n","            \"method\": method,\n","            \"lower\": lower,\n","            \"upper\": upper,\n","        }\n","\n","    def record_outlier_affected(self, col: str, n: int) -> None:\n","        self._data[\"phase_c\"][\"outlier_rows_affected\"][col] = n\n","\n","    def to_dict(self) -> dict:\n","        return self._data\n","\n","    def save(self, path: Path) -> None:\n","        with open(path, \"w\", encoding=\"utf-8\") as fh:\n","            json.dump(self._data, fh, ensure_ascii=False, indent=2, default=str)\n","\n","        logger.info(\"Data quality report lưu tại → %s\", path)\n","\n","    def log_summary(self) -> None:\n","        a = self._data[\"phase_a\"]\n","        b = self._data[\"phase_b\"]\n","\n","        _print_step(\"DATA QUALITY SUMMARY\")\n","        _print_stat(\"Rows at start\", a[\"rows_at_start\"])\n","        _print_stat(\"Header rows removed\", a[\"header_rows_removed\"])\n","        _print_stat(\"Duplicates removed\", a[\"duplicates_removed\"])\n","        _print_stat(\"Invalid rating removed\", a[\"invalid_rating_removed\"])\n","        _print_stat(\"explain → hours parsed\", a[\"explain_parsed_to_hours\"])\n","        _print_stat(\"joined_time → months parsed\", a[\"joined_time_parsed_to_months\"])\n","        _print_stat(\"Split sizes\", b.get(\"split_rows\", {}))"]},{"cell_type":"markdown","metadata":{"id":"BlvTCKnSKWKq"},"source":["# **Schema Validator**"]},{"cell_type":"code","execution_count":24,"metadata":{"id":"z_3YvcB5KWSl","executionInfo":{"status":"ok","timestamp":1779903736955,"user_tz":-420,"elapsed":6,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class SchemaValidator:\n","    def __init__(self, config: PipelineConfig) -> None:\n","        self.cfg = config\n","\n","    def validate(self, df: pd.DataFrame) -> None:\n","        _print_step(\"Phase 0 — Schema Validation\")\n","        self._check_required_columns(df)\n","        self._check_important_columns(df)\n","        self._check_fully_empty_columns(df)\n","        _print_stat(\"Total columns\", len(df.columns))\n","        _print_stat(\"Total rows\", len(df))\n","        print(\"  [OK] Schema validation passed.\")\n","\n","    def _check_required_columns(self, df: pd.DataFrame) -> None:\n","        missing = [c for c in self.cfg.required_columns if c not in df.columns]\n","        if missing:\n","            raise ValueError(f\"SchemaValidator: thiếu cột bắt buộc: {missing}\")\n","\n","    def _check_important_columns(self, df: pd.DataFrame) -> None:\n","        for col in self.cfg.important_columns:\n","            if col not in df.columns:\n","                logger.warning(\"Cột quan trọng '%s' không tồn tại — sẽ bỏ qua.\", col)\n","\n","    @staticmethod\n","    def _check_fully_empty_columns(df: pd.DataFrame) -> None:\n","        fully_empty = [c for c in df.columns if df[c].isna().all()]\n","        if fully_empty:\n","            logger.warning(\"Các cột rỗng hoàn toàn: %s\", fully_empty)\n","            _print_stat(\"Fully empty columns\", fully_empty)"]},{"cell_type":"markdown","metadata":{"id":"CTuvzOawKWbb"},"source":["# **Data Cleaner**"]},{"cell_type":"code","execution_count":25,"metadata":{"id":"cc-8rtZHKWjm","executionInfo":{"status":"ok","timestamp":1779903737117,"user_tz":-420,"elapsed":146,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class DataCleaner:\n","    _TEXT_SENTINELS: frozenset[str] = frozenset({\"nan\", \"none\", \"null\", \"na\", \"\"})\n","\n","    # Sentinel strings cho ID columns\n","    # data load bằng dtype=str nên chưa phải NaN thật\n","    _ID_SENTINELS: frozenset[str] = frozenset({\"nan\", \"none\", \"null\", \"na\", \"\", \"0\"})\n","\n","    _CRITICAL_ID_COLS: list[str] = [\"customer_id\", \"seller_id\"]\n","\n","    _EXPLAIN_TO_HOURS: dict[str, float] = {\n","        \"năm\": 8640.0,\n","        \"tháng\": 720.0,\n","        \"ngày\": 24.0,\n","        \"giờ\": 1.0,\n","        \"phút\": 1.0 / 60.0,\n","    }\n","\n","    _JOINED_TO_MONTHS: dict[str, float] = {\n","        \"năm\": 12.0,\n","        \"tháng\": 1.0,\n","        \"ngày\": 1.0 / 30.0,\n","    }\n","\n","    def __init__(self, config: PipelineConfig, report: DataQualityReport) -> None:\n","        self.cfg = config\n","        self.report = report\n","\n","\n","    def _filter_by_min_date(self, df: pd.DataFrame) -> pd.DataFrame:\n","        col = \"review_created_date\"\n","        if col not in df.columns:\n","            return df\n","        min_date = pd.Timestamp(\"2020-01-01\")\n","        mask = df[col] < min_date\n","        n = int(mask.sum())\n","        if n:\n","            logger.info(\"filter_by_min_date: removed %d rows before %s.\", n, min_date.date())\n","        return df.loc[~mask].reset_index(drop=True)\n","\n","\n","    def clean(self, df: pd.DataFrame) -> pd.DataFrame:\n","        df = df.copy()\n","        self.report.record_start(len(df))\n","\n","        _print_step(\"Phase A — Row-wise Cleaning\")\n","        _print_stat(\"Rows at start\", len(df))\n","\n","        steps = [\n","            # Bước 1: xóa header nhúng\n","            (\"Remove embedded headers\", self._remove_embedded_headers),\n","\n","            # Bước 2: xóa missing critical IDs trước cast_dtypes\n","            (\"Remove missing critical IDs\", self._remove_missing_critical_ids),\n","\n","            # Bước 3+: phần còn lại\n","            (\"Cast dtypes\", self._cast_dtypes),\n","            (\"Parse dates\", self._parse_dates),\n","            (\"Filter reviews before 2020\", self._filter_by_min_date),\n","            (\"Parse explain → usage_hours\", self._parse_explain_to_hours),\n","            (\"Parse customer_joined_time → months\", self._parse_joined_time_to_months),\n","            (\"Dedup by review_id\", self._drop_duplicates_by_review_id),\n","            (\"Dedup by (customer, product, content)\", self._drop_duplicates_by_customer_product_content),\n","            (\"Dedup by normalised content\", self._drop_duplicates_by_normalised_content),\n","            (\"Remove invalid ratings\", self._remove_invalid_ratings),\n","            (\"Nullify impossible counts\", self._nullify_impossible_counts),\n","            (\"Clean text content\", self._clean_text_content),\n","        ]\n","\n","        for step_name, step_fn in steps:\n","            rows_before = len(df)\n","            df = step_fn(df)\n","            rows_after = len(df)\n","\n","            removed = rows_before - rows_after\n","\n","            if removed > 0:\n","                _print_stat(f\"  → {step_name}\", f\"removed {removed} rows\")\n","            else:\n","                print(f\"  [OK] {step_name}\")\n","\n","        _print_stat(\"Rows after Phase A\", len(df))\n","        logger.info(\"Phase A — done (rows=%d, cols=%d)\", *df.shape)\n","\n","        return df\n","\n","    # ─────────────────────────────────────────────────────────────────────\n","    # Xóa hàng thiếu customer_id hoặc seller_id\n","    # ─────────────────────────────────────────────────────────────────────\n","\n","    def _remove_missing_critical_ids(self, df: pd.DataFrame) -> pd.DataFrame:\n","        \"\"\"\n","        Xóa hàng có customer_id hoặc seller_id bị missing.\n","\n","        Chạy TRƯỚC _cast_dtypes vì data load bằng dtype=str:\n","          - NaN thật: bắt bằng isna()\n","          - String sentinel: \"nan\", \"none\", \"null\", \"na\", \"\" → bắt bằng _ID_SENTINELS\n","          - ID = \"0\": vô nghĩa về mặt nghiệp vụ → cũng loại\n","\n","        Lý do xóa thay vì impute:\n","          - Đây là foreign key — không có giá trị thay thế có nghĩa.\n","          - Gán nhãn suspicious cần groupby customer_id và seller_id.\n","          - Hàng không có ID không thể gán vào entity nào → loại bỏ.\n","        \"\"\"\n","        cols_present = [c for c in self._CRITICAL_ID_COLS if c in df.columns]\n","\n","        if not cols_present:\n","            logger.warning(\n","                \"_remove_missing_critical_ids: không tìm thấy cột nào \"\n","                \"trong %s — bỏ qua.\",\n","                self._CRITICAL_ID_COLS,\n","            )\n","            return df\n","\n","        def _is_missing_id(series: pd.Series) -> pd.Series:\n","            \"\"\"True nếu giá trị là NaN thật hoặc string sentinel.\"\"\"\n","            is_null = series.isna()\n","            is_sentinel = (\n","                series.astype(str)\n","                .str.strip()\n","                .str.lower()\n","                .isin(self._ID_SENTINELS)\n","            )\n","            return is_null | is_sentinel\n","\n","        # Ghi audit log chi tiết từng cột trước khi xóa\n","        for col in cols_present:\n","            n_col_miss = int(_is_missing_id(df[col]).sum())\n","\n","            if n_col_miss > 0:\n","                self.report.record_missing_critical_ids(col, n_col_miss)\n","                logger.warning(\n","                    \"Critical ID '%s': %d missing/sentinel → sẽ bị xóa.\",\n","                    col,\n","                    n_col_miss,\n","                )\n","\n","        # Mask: True nếu ÍT NHẤT 1 cột đang missing\n","        missing_mask = pd.concat(\n","            [_is_missing_id(df[col]) for col in cols_present],\n","            axis=1,\n","        ).any(axis=1)\n","\n","        n_removed = int(missing_mask.sum())\n","\n","        if n_removed > 0:\n","            _print_stat(\n","                \"remove_missing_critical_ids\",\n","                f\"{n_removed} hàng bị xóa (thiếu ít nhất 1 trong {cols_present})\",\n","            )\n","\n","        return df.loc[~missing_mask].reset_index(drop=True)\n","\n","    # ── Embedded header removal ───────────────────────────────────────────\n","\n","    def _remove_embedded_headers(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"rating\" not in df.columns:\n","            return df\n","\n","        mask = df[\"rating\"].astype(str).str.strip() == \"rating\"\n","        n = int(mask.sum())\n","\n","        self.report.record_header_removal(n)\n","\n","        if n:\n","            logger.warning(\"Removed %d embedded header row(s).\", n)\n","\n","        return df.loc[~mask].reset_index(drop=True)\n","\n","    # ── Dtype casting ─────────────────────────────────────────────────────\n","\n","    @staticmethod\n","    def _cast_dtypes(df: pd.DataFrame) -> pd.DataFrame:\n","        id_cols: list[str] = [\n","            \"review_id\",\n","            \"product_id\",\n","            \"seller_id\",\n","            \"customer_id\",\n","        ]\n","\n","        numeric_cols: list[str] = [\n","            \"rating\",\n","            \"num_images\",\n","            \"num_vote_agree\",\n","            \"customer_total_review\",\n","            \"customer_total_thank\",\n","            \"score\",\n","            \"new_score\",\n","            \"content_length\",\n","            \"thank_count\",\n","        ]\n","\n","        for col in id_cols:\n","            if col in df.columns:\n","                df[col] = pd.to_numeric(df[col], errors=\"coerce\").astype(\"Int64\")\n","\n","        for col in numeric_cols:\n","            if col in df.columns:\n","                df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n","\n","        return df\n","\n","    # ── Date parsing ──────────────────────────────────────────────────────\n","\n","    @staticmethod\n","    def _parse_dates(df: pd.DataFrame) -> pd.DataFrame:\n","        date_cols = [\"review_created_date\", \"delivery_date\"]\n","\n","        for col in date_cols:\n","            if col not in df.columns:\n","                continue\n","\n","            try:\n","                df[col] = pd.to_datetime(\n","                    df[col],\n","                    format=\"mixed\",\n","                    dayfirst=True,\n","                    errors=\"coerce\",\n","                )\n","            except TypeError:\n","                df[col] = pd.to_datetime(\n","                    df[col],\n","                    dayfirst=True,\n","                    errors=\"coerce\",\n","                )\n","\n","            n_nat = int(df[col].isna().sum())\n","\n","            if n_nat:\n","                logger.info(\"'%s': %d giá trị không parse được → NaT.\", col, n_nat)\n","\n","        return df\n","\n","    # ── explain → usage_hours ─────────────────────────────────────────────\n","\n","    def _parse_explain_to_hours(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"explain\" not in df.columns:\n","            return df\n","\n","        pattern = re.compile(\n","            r\"(\\d+(?:\\.\\d+)?)\\s*(năm|tháng|ngày|giờ|phút)\",\n","            flags=re.IGNORECASE,\n","        )\n","\n","        raw = df[\"explain\"].copy()\n","        stats = {\"success\": 0, \"fail\": 0}\n","\n","        def _to_hours(text):\n","            if pd.isna(text):\n","                return np.nan\n","\n","            m = pattern.search(str(text))\n","\n","            if not m:\n","                stats[\"fail\"] += 1\n","                return np.nan\n","\n","            stats[\"success\"] += 1\n","\n","            value = float(m.group(1))\n","            unit = m.group(2).lower()\n","            factor = self._EXPLAIN_TO_HOURS.get(unit, np.nan)\n","\n","            return round(value * factor, 4)\n","\n","        original_null = int(raw.isna().sum())\n","\n","        df[\"explain\"] = raw.apply(_to_hours)\n","\n","        new_null = int(df[\"explain\"].isna().sum())\n","\n","        self.report.record_explain_parsed(stats[\"success\"])\n","\n","        logger.info(\n","            \"explain → hours: %d success, %d failed, nulls %d -> %d\",\n","            stats[\"success\"],\n","            stats[\"fail\"],\n","            original_null,\n","            new_null,\n","        )\n","\n","        return df\n","\n","    # ── customer_joined_time → joined_months ──────────────────────────────\n","\n","    def _parse_joined_time_to_months(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"customer_joined_time\" not in df.columns:\n","            return df\n","\n","        pattern = re.compile(\n","            r\"(\\d+(?:\\.\\d+)?)\\s*(năm|tháng|ngày)\",\n","            flags=re.IGNORECASE,\n","        )\n","\n","        raw = df[\"customer_joined_time\"].copy()\n","        stats = {\"success\": 0, \"fail\": 0}\n","\n","        def _to_months(text: Any) -> Optional[float]:\n","            if pd.isna(text):\n","                return np.nan\n","\n","            m = pattern.search(str(text))\n","\n","            if not m:\n","                stats[\"fail\"] += 1\n","                return np.nan\n","\n","            stats[\"success\"] += 1\n","\n","            value = float(m.group(1))\n","            unit = m.group(2).lower()\n","\n","            if unit == \"ngày\":\n","                return 0.0\n","\n","            factor = self._JOINED_TO_MONTHS.get(unit, np.nan)\n","\n","            return round(value * factor, 4)\n","\n","        original_null = int(raw.isna().sum())\n","\n","        df[\"customer_joined_time\"] = raw.apply(_to_months)\n","\n","        new_null = int(df[\"customer_joined_time\"].isna().sum())\n","\n","        self.report.record_joined_time_parsed(stats[\"success\"])\n","\n","        logger.info(\n","            \"customer_joined_time → months: %d success, %d failed, nulls %d -> %d\",\n","            stats[\"success\"],\n","            stats[\"fail\"],\n","            original_null,\n","            new_null,\n","        )\n","\n","        return df\n","\n","    # ── Deduplication ─────────────────────────────────────────────────────\n","\n","    def _drop_duplicates_by_review_id(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"review_id\" not in df.columns:\n","            return df\n","\n","        before = len(df)\n","\n","        df = df.drop_duplicates(subset=[\"review_id\"], keep=\"first\")\n","\n","        n = before - len(df)\n","\n","        self.report.record_dedup(\"by_review_id\", n)\n","\n","        if n:\n","            logger.info(\"Dedup by review_id: removed %d rows.\", n)\n","\n","        return df.reset_index(drop=True)\n","\n","    def _drop_duplicates_by_customer_product_content(\n","        self,\n","        df: pd.DataFrame,\n","    ) -> pd.DataFrame:\n","        key_cols = [\"customer_id\", \"product_id\", \"content\"]\n","\n","        if not all(c in df.columns for c in key_cols):\n","            return df\n","\n","        has_content = df[\"content\"].notna()\n","\n","        dupe_idx = df[has_content][\n","            df[has_content].duplicated(subset=key_cols, keep=\"first\")\n","        ].index\n","\n","        before = len(df)\n","\n","        df = df.drop(index=dupe_idx)\n","\n","        n = before - len(df)\n","\n","        self.report.record_dedup(\"by_customer_product_content\", n)\n","\n","        if n:\n","            logger.info(\n","                \"Dedup by (customer_id, product_id, content): removed %d rows.\",\n","                n,\n","            )\n","\n","        return df.reset_index(drop=True)\n","\n","    @staticmethod\n","    def _normalise_text_for_dedup(text: pd.Series) -> pd.Series:\n","        return (\n","            text.astype(str)\n","            .apply(lambda s: unicodedata.normalize(\"NFC\", s))\n","            .str.lower()\n","            .str.replace(r\"\\s+\", \" \", regex=True)\n","            .str.strip()\n","        )\n","\n","    def _drop_duplicates_by_normalised_content(\n","        self,\n","        df: pd.DataFrame,\n","    ) -> pd.DataFrame:\n","        required_cols = [\"content\", \"customer_id\", \"product_id\"]\n","\n","        if not all(c in df.columns for c in required_cols):\n","            return df\n","\n","        has_content = df[\"content\"].notna()\n","\n","        subset = df.loc[has_content].copy()\n","        subset[\"_norm_content\"] = self._normalise_text_for_dedup(subset[\"content\"])\n","\n","        dupe_idx = subset[\n","            subset.duplicated(\n","                subset=[\"customer_id\", \"product_id\", \"_norm_content\"],\n","                keep=\"first\",\n","            )\n","        ].index\n","\n","        before = len(df)\n","\n","        df = df.drop(index=dupe_idx)\n","\n","        n = before - len(df)\n","\n","        self.report.record_dedup(\"by_normalised_content\", n)\n","\n","        if n:\n","            logger.info(\n","                \"Dedup by (customer_id, product_id, normalised content): removed %d rows.\",\n","                n,\n","            )\n","\n","        return df.reset_index(drop=True)\n","\n","    # ── Rating validation ─────────────────────────────────────────────────\n","\n","    def _remove_invalid_ratings(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"rating\" not in df.columns:\n","            return df\n","\n","        valid_as_floats = {float(r) for r in self.cfg.valid_ratings}\n","\n","        is_valid_or_null = df[\"rating\"].isin(valid_as_floats) | df[\"rating\"].isna()\n","\n","        n = int((~is_valid_or_null).sum())\n","\n","        self.report.record_invalid_rating(n)\n","\n","        if n:\n","            logger.warning(\"Removed %d rows with invalid rating.\", n)\n","\n","        return df.loc[is_valid_or_null].reset_index(drop=True)\n","\n","    # ── Impossible count values ───────────────────────────────────────────\n","\n","    def _nullify_impossible_counts(self, df: pd.DataFrame) -> pd.DataFrame:\n","        non_negative_cols = [\n","            \"num_images\",\n","            \"num_vote_agree\",\n","            \"customer_total_review\",\n","            \"customer_total_thank\",\n","        ]\n","\n","        for col in non_negative_cols:\n","            if col not in df.columns:\n","                continue\n","\n","            neg_mask = df[col] < 0\n","            n = int(neg_mask.sum())\n","\n","            if n:\n","                logger.warning(\"'%s': %d negative values → NaN.\", col, n)\n","                _print_stat(f\"  {col} negative → NaN\", n)\n","                self.report.record_impossible_values(col, n)\n","                df.loc[neg_mask, col] = np.nan\n","\n","        return df\n","\n","    # ── Text cleaning ─────────────────────────────────────────────────────\n","\n","    def _clean_text_content(self, df: pd.DataFrame) -> pd.DataFrame:\n","        if \"content\" not in df.columns:\n","            return df\n","\n","        has_data = df[\"content\"].notna()\n","\n","        stripped = df.loc[has_data, \"content\"].astype(str).str.strip()\n","        is_sentinel = stripped.str.lower().isin(self._TEXT_SENTINELS)\n","\n","        df.loc[has_data, \"content\"] = stripped.where(\n","            ~is_sentinel,\n","            other=np.nan,\n","        )\n","\n","        return df"]},{"cell_type":"markdown","metadata":{"id":"llxsQKaWKWue"},"source":["# **Data Splitter**"]},{"cell_type":"code","execution_count":26,"metadata":{"id":"cz964TAIBFV5","executionInfo":{"status":"ok","timestamp":1779903737125,"user_tz":-420,"elapsed":3,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class DataSplitter:\n","\n","    def __init__(self, config: PipelineConfig, report: DataQualityReport) -> None:\n","        self.cfg    = config\n","        self.report = report\n","\n","    def split(self, df: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:\n","        _print_step(\"Phase B — Customer-based Train/Val/Test Split\")\n","        logger.info(\n","            \"Splitting: train=%.0f%% val=%.0f%% test=%.0f%%\",\n","            self.cfg.train_ratio * 100,\n","            self.cfg.val_ratio   * 100,\n","            self.cfg.test_ratio  * 100,\n","        )\n","\n","        customers = df[\"customer_id\"].unique()\n","        rng = np.random.default_rng(self.cfg.random_state)\n","        rng.shuffle(customers)\n","\n","        n         = len(customers)\n","        train_end = int(n * self.cfg.train_ratio)\n","        val_end   = int(n * (self.cfg.train_ratio + self.cfg.val_ratio))\n","\n","        train_ids = set(customers[:train_end])\n","        val_ids   = set(customers[train_end:val_end])\n","        test_ids  = set(customers[val_end:])\n","\n","        train = df[df[\"customer_id\"].isin(train_ids)].copy()\n","        val   = df[df[\"customer_id\"].isin(val_ids)].copy()\n","        test  = df[df[\"customer_id\"].isin(test_ids)].copy()\n","\n","        self.report.record_split(len(train), len(val), len(test))\n","        _print_stat(\"train\", len(train))\n","        _print_stat(\"val\",   len(val))\n","        _print_stat(\"test\",  len(test))\n","        logger.info(\n","            \"Split done: train=%d | val=%d | test=%d\",\n","            len(train), len(val), len(test)\n","        )\n","        return train, val, test"]},{"cell_type":"markdown","metadata":{"id":"V-MoaZrQNcT-"},"source":["# **Outlier Handler**"]},{"cell_type":"code","execution_count":27,"metadata":{"id":"TYGdUJpvNdCF","executionInfo":{"status":"ok","timestamp":1779903737145,"user_tz":-420,"elapsed":17,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class OutlierHandler:\n","\n","      def __init__(self, config: PipelineConfig, report: DataQualityReport) -> None:\n","          self.cfg        = config\n","          self.report     = report\n","          self._bounds: dict[str, tuple[Optional[float], Optional[float]]] = {}\n","          self._is_fitted = False\n","\n","      def decide_mode(self, train: pd.DataFrame) -> OutlierMode:\n","          total_rows = len(train)\n","          estimated_outlier_ratio = 0.0\n","          for col, strategy in self.cfg.outlier_strategies.items():\n","              if col not in train.columns:\n","                  continue\n","              series = train[col].dropna()\n","              if len(series) == 0:\n","                  continue\n","              lower, upper = self._compute_bounds(series, strategy)\n","              mask = self._build_outlier_mask(series, lower, upper)\n","              estimated_outlier_ratio += mask.mean()\n","          estimated_outlier_ratio /= max(len(self.cfg.outlier_strategies), 1)\n","          _print_stat(\"Estimated outlier ratio\", round(estimated_outlier_ratio, 4))\n","          if estimated_outlier_ratio > 0.08:\n","              return OutlierMode.CAP\n","          else:\n","              return OutlierMode.REMOVE\n","\n","      def fit(self, train: pd.DataFrame) -> \"OutlierHandler\":\n","          _print_step(\"Phase C1 — Outlier Handler: Fitting on TRAIN\")\n","          self._bounds = {}\n","          mode = self.decide_mode(train)\n","          self.cfg.outlier_mode = mode\n","          self.report.record_outlier_mode(mode.name)\n","\n","          for col, strategy in self.cfg.outlier_strategies.items():\n","              if col not in train.columns:\n","                  logger.debug(\"OutlierHandler.fit: '%s' không tồn tại — bỏ qua.\", col)\n","                  continue\n","              series       = train[col].dropna()\n","              lower, upper = self._compute_bounds(series, strategy)\n","              self._bounds[col] = (lower, upper)\n","              self.report.record_outlier_bounds(\n","                  col, strategy.method.name,\n","                  round(lower, 4) if lower is not None else None,\n","                  round(upper, 4) if upper is not None else None,\n","              )\n","              lower_str = f\"{lower:.4f}\" if lower is not None else \"—\"\n","              upper_str = f\"{upper:.4f}\" if upper is not None else \"—\"\n","              _print_stat(f\"  {col} [{strategy.method.name}]\", f\"lower={lower_str}, upper={upper_str}\")\n","              logger.info(\n","                  \"OutlierHandler — %-35s  method=%-10s  lower=%s  upper=%s\",\n","                  col, strategy.method.name,\n","                  f\"{lower:.4f}\" if lower is not None else \"—\",\n","                  f\"{upper:.4f}\" if upper is not None else \"—\",\n","              )\n","\n","          self._is_fitted = True\n","          _print_stat(\"Outlier mode\", self.cfg.outlier_mode.name)\n","          return self\n","\n","      def transform(self, df: pd.DataFrame) -> pd.DataFrame:\n","          self._assert_fitted()\n","          df = df.copy()\n","          for col, (lower, upper) in self._bounds.items():\n","              if col not in df.columns:\n","                  continue\n","              mask = self._build_outlier_mask(df[col], lower, upper)\n","              n_affected = int(mask.sum())\n","              self.report.record_outlier_affected(col, n_affected)\n","              _print_stat(f\"  {col} outliers\", n_affected)\n","          if self.cfg.outlier_mode == OutlierMode.REMOVE:\n","              return self._remove_outlier_rows(df)\n","          return self._cap_outlier_values(df)\n","\n","      def fit_transform(self, train: pd.DataFrame, *others: pd.DataFrame) -> tuple[pd.DataFrame, ...]:\n","          self.fit(train)\n","          return (self.transform(train),) + tuple(self.transform(df) for df in others)\n","\n","      @staticmethod\n","      def _compute_bounds(series: pd.Series, strategy: OutlierStrategyConfig) -> tuple[Optional[float], Optional[float]]:\n","          if strategy.method == OutlierMethod.IQR:\n","              q1  = float(series.quantile(0.25))\n","              q3  = float(series.quantile(0.75))\n","              iqr = q3 - q1\n","              upper = q3 + strategy.iqr_multiplier * iqr\n","              lower = (\n","                  (q1 - strategy.iqr_multiplier * iqr)\n","                  if strategy.lower_pct > 0 else None\n","              )\n","              return lower, upper\n","\n","          if strategy.method == OutlierMethod.PERCENTILE:\n","              upper = (\n","                  float(series.quantile(strategy.upper_pct))\n","                  if strategy.upper_pct < 1.0 else None\n","              )\n","              lower = (\n","                  float(series.quantile(strategy.lower_pct))\n","                  if strategy.lower_pct > 0.0 else None\n","              )\n","              return lower, upper\n","\n","          if strategy.method == OutlierMethod.DOMAIN:\n","              return strategy.domain_min, strategy.domain_max\n","\n","          raise ValueError(f\"OutlierMethod không hợp lệ: {strategy.method!r}\")\n","\n","      @staticmethod\n","      def _build_outlier_mask(series: pd.Series, lower: Optional[float], upper: Optional[float]) -> pd.Series:\n","          mask = pd.Series(False, index=series.index)\n","          if upper is not None:\n","              mask |= series > upper\n","          if lower is not None:\n","              mask |= series < lower\n","          return mask\n","\n","      def _remove_outlier_rows(self, df: pd.DataFrame) -> pd.DataFrame:\n","          keep = pd.Series(True, index=df.index)\n","          for col, (lower, upper) in self._bounds.items():\n","              if col not in df.columns:\n","                  continue\n","              is_outlier = self._build_outlier_mask(df[col], lower, upper)\n","              keep &= ~is_outlier | df[col].isna()\n","          n_dropped = int((~keep).sum())\n","          _print_stat(\"  [REMOVE] Rows dropped (outlier)\", n_dropped)\n","          logger.info(\"OutlierHandler (REMOVE): dropped %d rows.\", n_dropped)\n","          return df.loc[keep].reset_index(drop=True)\n","\n","      def _cap_outlier_values(self, df: pd.DataFrame) -> pd.DataFrame:\n","          for col, (lower, upper) in self._bounds.items():\n","              if col not in df.columns:\n","                  continue\n","              clip_lower = lower if lower is not None else df[col].min()\n","              clip_upper = upper if upper is not None else df[col].max()\n","              df[col] = df[col].clip(lower=clip_lower, upper=clip_upper)\n","          _print_stat(\"  [CAP] Mode: values clipped at bounds, no rows removed\", \"\")\n","          return df\n","\n","      def _assert_fitted(self) -> None:\n","          if not self._is_fitted:\n","              raise RuntimeError(\"OutlierHandler: gọi fit() trước transform().\")"]},{"cell_type":"markdown","metadata":{"id":"GLy7rA3_KW_e"},"source":["# **Missing Value Handler**"]},{"cell_type":"code","execution_count":28,"metadata":{"id":"optqDf83KXH-","executionInfo":{"status":"ok","timestamp":1779903737149,"user_tz":-420,"elapsed":9,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class MissingValueHandler:\n","\n","    _ID_SUBSTRINGS          = (\"_id\",)\n","    _MNAR_NUMERIC_SENTINEL  = -999\n","    _MNAR_CATEGORY_SENTINEL = \"Missing\"\n","\n","    def __init__(self, config: PipelineConfig, report: DataQualityReport) -> None:\n","        self.cfg               = config\n","        self.report            = report\n","        self._strategies:      dict[str, Any] = {}\n","        self._original_dtypes: dict[str, Any] = {}\n","        self._is_fitted        = False\n","\n","    def fit(self, train: pd.DataFrame) -> \"MissingValueHandler\":\n","        _print_step(\"Phase C2 — Missing Value Handler: Fitting on TRAIN\")\n","        self._strategies      = {}\n","        self._original_dtypes = {}\n","\n","        for col in train.columns:\n","            if self._is_id_column(col):\n","                continue\n","            n_missing = int(train[col].isna().sum())\n","            if n_missing == 0:\n","                continue\n","\n","            self._original_dtypes[col] = train[col].dtype\n","            self.report.record_missing_before_impute(col, n_missing)\n","\n","            mechanism  = self._classify_mechanism(train, col)\n","            fill_value = self._derive_fill_value(train, col, mechanism)\n","            self._strategies[col] = fill_value\n","\n","            self.report.record_missing_mechanism(col, mechanism, fill_value)\n","            _print_stat(\n","                f\"  {col}\",\n","                f\"missing={n_missing}, mech={mechanism.value}, fill={fill_value!r}\",\n","            )\n","            logger.debug(\n","                \"MissingValueHandler — %-38s  miss=%d  mech=%-4s  fill=%r\",\n","                col, n_missing, mechanism.value, fill_value,\n","            )\n","\n","        logger.info(\n","            \"MissingValueHandler fitted — %d cột có imputation strategies.\",\n","            len(self._strategies),\n","        )\n","        self._is_fitted = True\n","        return self\n","\n","    def transform(self, df: pd.DataFrame) -> pd.DataFrame:\n","        self._assert_fitted()\n","        df = df.copy()\n","\n","        for col, fill_value in self._strategies.items():\n","            if col not in df.columns:\n","                continue\n","            df[col] = df[col].fillna(fill_value)\n","            original_dtype = self._original_dtypes.get(col)\n","            if original_dtype is not None:\n","                try:\n","                    df[col] = df[col].astype(original_dtype)\n","                except (ValueError, TypeError):\n","                    pass\n","\n","        return df\n","\n","    def fit_transform(self, train: pd.DataFrame, *others: pd.DataFrame) -> tuple[pd.DataFrame, ...]:\n","        self.fit(train)\n","        return (self.transform(train),) + tuple(self.transform(df) for df in others)\n","\n","    def _is_id_column(self, col: str) -> bool:\n","        return any(sub in col.lower() for sub in self._ID_SUBSTRINGS)\n","\n","    def _classify_mechanism(self, train: pd.DataFrame, col: str) -> MissingMechanism:\n","        if col in self.cfg.missing_mechanism_overrides:\n","            override = self.cfg.missing_mechanism_overrides[col]\n","            logger.debug(\"'%s' mechanism forced → %s (config).\", col, override.value)\n","            return override\n","\n","        miss_rate = train[col].isna().mean()\n","        if miss_rate >= self.cfg.mnar_miss_rate_threshold:\n","            return MissingMechanism.MNAR\n","\n","        missingness_flag = train[col].isna().astype(float)\n","        other_numerics   = (\n","            train.select_dtypes(include=\"number\")\n","                .drop(columns=[col], errors=\"ignore\")\n","        )\n","        if not other_numerics.empty:\n","            max_abs_corr = other_numerics.corrwith(missingness_flag).abs().max()\n","            if pd.notna(max_abs_corr) and max_abs_corr >= self.cfg.mar_corr_threshold:\n","                return MissingMechanism.MAR\n","\n","        return MissingMechanism.MCAR\n","\n","    @staticmethod\n","    def _derive_fill_value(train: pd.DataFrame, col: str, mechanism: MissingMechanism) -> Any:\n","        is_numeric = pd.api.types.is_numeric_dtype(train[col])\n","\n","        if is_numeric:\n","            if mechanism == MissingMechanism.MNAR:\n","                return MissingValueHandler._MNAR_NUMERIC_SENTINEL\n","            if mechanism == MissingMechanism.MAR:\n","                return float(train[col].median())\n","            return float(train[col].mean())\n","\n","        if mechanism == MissingMechanism.MNAR:\n","            return MissingValueHandler._MNAR_CATEGORY_SENTINEL\n","        mode_vals = train[col].mode(dropna=True)\n","        return mode_vals.iloc[0] if not mode_vals.empty else \"Unknown\"\n","\n","    def _assert_fitted(self) -> None:\n","        if not self._is_fitted:\n","            raise RuntimeError(\"MissingValueHandler: gọi fit() trước transform().\")"]},{"cell_type":"markdown","metadata":{"id":"YUENP4iOcOsB"},"source":["# **Tiki Review Pipeline**"]},{"cell_type":"code","execution_count":29,"metadata":{"id":"lix93mMiNyWE","executionInfo":{"status":"ok","timestamp":1779903737272,"user_tz":-420,"elapsed":4,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[],"source":["class TikiReviewPipeline:\n","\n","    def __init__(self, config: Optional[PipelineConfig] = None) -> None:\n","        self.cfg    = config or PipelineConfig()\n","        self.report = DataQualityReport()\