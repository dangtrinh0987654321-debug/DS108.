ite, tham số request, headers, cookies/token hoặc cấu trúc JSON trả về, code crawl có thể bị lỗi hoặc thu được dữ liệu thiếu. \\\n","Khi gặp lỗi, cần kiểm tra lại request hiện tại trong Developer Tools/F12 của trình duyệt và cập nhật lại endpoint, headers, params hoặc parser cho phù hợp.\n"],"metadata":{"id":"8aEL6j-X_JHh"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"4LcywbSX4Xqm","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1778792101426,"user_tz":-420,"elapsed":8053,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}},"outputId":"01ee2e8e-93a2-467e-bb8a-56756ba6fb2b"},"outputs":[{"output_type":"stream","name":"stderr","text":["\rCrawling product IDs:   0%|          | 0/2 [00:00<?, ?it/s]"]},{"output_type":"stream","name":"stdout","text":["request success!\n"]},{"output_type":"stream","name":"stderr","text":["\rCrawling product IDs:  50%|█████     | 1/2 [00:04<00:04,  4.29s/it]"]},{"output_type":"stream","name":"stdout","text":["request success!\n"]},{"output_type":"stream","name":"stderr","text":["Crawling product IDs: 100%|██████████| 2/2 [00:08<00:00,  4.01s/it]"]},{"output_type":"stream","name":"stdout","text":["Saved 20 products to data/tiki_pt_phukienchamsocxe.csv\n"]},{"output_type":"stream","name":"stderr","text":["\n"]}],"source":["# CONFIG\n","QUERY = \"phu kien cham soc xe\"\n","NUM_PAGES = 50\n","LIMIT = 40\n","\n","PRODUCT_API_URL = \"https://tiki.vn/api/v2/products\"\n","PRODUCT_ID_OUTPUT_PATH = \"data/tiki_pt_phukienchamsocxe.csv\"\n","\n","\n","# LOAD SECRETS\n","def load_secrets(group_name):\n","    \"\"\"\n","    Load optional cookies/tokens from secrets.json.\n","    Do NOT commit secrets.json to GitHub.\n","    \"\"\"\n","    secrets_path = Path(\"secrets.json\")\n","\n","    if not secrets_path.exists():\n","        return {}\n","\n","    with open(secrets_path, \"r\", encoding=\"utf-8\") as f:\n","        secrets = json.load(f)\n","\n","    return secrets.get(group_name, {})\n","\n","\n","product_secrets = load_secrets(\"product_id_crawler\")\n","\n","cookies = product_secrets.get(\"cookies\", {})\n","x_guest_token = product_secrets.get(\"x_guest_token\", \"\")\n","trackity_id = product_secrets.get(\"trackity_id\", \"\")\n","\n","\n","# HEADERS AND PARAMS\n","headers = {\n","    \"User-Agent\": (\n","        \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) \"\n","        \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n","        \"Chrome/148.0.0.0 Safari/537.36\"\n","    ),\n","    \"Accept\": \"application/json, text/plain, */*\",\n","    \"Accept-Language\": \"vi-VN,vi;q=0.9,fr-FR;q=0.8,fr;q=0.7,en-US;q=0.6,en;q=0.5\",\n","    \"Referer\": f\"https://tiki.vn/search?q={quote_plus(QUERY)}\",\n","    \"Connection\": \"keep-alive\",\n","    \"TE\": \"Trailers\",\n","}\n","\n","if x_guest_token:\n","    headers[\"x-guest-token\"] = x_guest_token\n","\n","\n","params = {\n","    \"limit\": str(LIMIT),\n","    \"include\": \"advertisement\",\n","    \"aggregations\": \"2\",\n","    \"q\": QUERY,\n","}\n","\n","if trackity_id:\n","    params[\"trackity_id\"] = trackity_id\n","\n","\n","# CRAWL PRODUCT IDS\n","product_id = []\n","\n","for i in tqdm(range(1, NUM_PAGES + 1), desc=\"Crawling product IDs\"):\n","    params[\"page\"] = i\n","\n","    response = requests.get(\n","        PRODUCT_API_URL,\n","        headers=headers,\n","        params=params,\n","        cookies=cookies,\n","        timeout=20\n","    )\n","\n","    if response.status_code == 200:\n","        print(\"request success!\")\n","\n","        data = response.json().get(\"data\", [])\n","\n","        for record in data:\n","            product_id.append({\n","                \"product_id\": record.get(\"id\"),\n","                \"name\": record.get(\"name\")\n","            })\n","    else:\n","        print(f\"request failed at page {i}, status code: {response.status_code}\")\n","\n","    time.sleep(random.randrange(3, 10))\n","\n","\n","# SAVE PRODUCT IDS\n","\n","Path(\"data\").mkdir(exist_ok=True)\n","\n","df_product = pd.DataFrame(product_id)\n","df_product.to_csv(PRODUCT_ID_OUTPUT_PATH, index=False, encoding=\"utf-8-sig\")\n","\n","print(f\"Saved {len(df_product)} products to {PRODUCT_ID_OUTPUT_PATH}\")"]},{"cell_type":"markdown","source":["# **Bước 3: Thu thập Review**\n","Đảm bảo Cell 1 đã chạy xong và file CSV tồn tại. Chỉnh config nếu cần, sau đó run cell.\n","\n","\n","```\n","PRODUCT_ID_INPUT_PATH  = \"data/tiki_pt_phukienchamsocxe.csv\"  # output của Cell 1\n","REVIEW_OUTPUT_PATH     = \"data/tiki_pt_review_phukienchamsocxe.csv\"\n","REVIEW_LIMIT = 5   # số review mỗi request (tăng lên để crawl nhanh hơn)\n","```\n","Với mỗi product_id, cell gọi GET /api/v2/reviews và phân trang cho đến khi hết review. Mỗi review được parse thành một dòng gồm các trường sau:\n","\n","\n","```\n","review_id | customer_id | rating | content | content_length\n","avatar | customer_joined_time | customer_total_review\n","review_created_date | delivery_date | explain\n","num_images | num_vote_agree | seller_id | ...\n","```\n","Crawl toàn bộ sản phẩm có thể mất vài giờ do delay trang. Nên chạy theo batch hoặc để chạy qua đêm.\\\n","**Lưu ý:** Khi crawl đôi khi sẽ gặp các product ID có rất nhiều review khiến cho việc crawl có thể sẽ vượt quá 12 tiếng, vượt session của google colab dẫn đến mất data của cả session, gây tốn thời gian. Vì vậy, khuyễn khích chia nhỏ file ID ra thành nhiều batch, lưu ý những loại sản phẩm thường có nhiều review hoặc áp dụng cơ chế checkpoint. Trong bài này thì nhóm dùng cách đầu tiên là chia nhỏ file ID. \\\n","Chú ý lưu ý của bước 2\n","\n"],"metadata":{"id":"NlZ72vIM9FO3"}},{"cell_type":"code","source":["# CONFIG\n","FULL_PRODUCT_ID_INPUT_PATH = \"data/tiki_pt_phukienchamsocxe.csv\"\n","CHUNK_DIR = Path(\"data/product_id_chunks\")\n","CHUNK_SIZE = 200\n","\n","# SPLIT PRODUCT ID FILE\n","CHUNK_DIR.mkdir(parents=True, exist_ok=True)\n","\n","df_id = pd.read_csv(FULL_PRODUCT_ID_INPUT_PATH, encoding=\"utf-8-sig\")\n","\n","num_chunks = math.ceil(len(df_id) / CHUNK_SIZE)\n","\n","for i in range(num_chunks):\n","    start = i * CHUNK_SIZE\n","    end = start + CHUNK_SIZE\n","\n","    df_chunk = df_id.iloc[start:end].copy()\n","\n","    chunk_path = CHUNK_DIR / f\"product_ids_part_{i+1:03d}.csv\"\n","    df_chunk.to_csv(chunk_path, index=False, encoding=\"utf-8-sig\")\n","\n","    print(f\"Saved {len(df_chunk)} products to {chunk_path}\")\n","\n","print(f\"\\nDone. Total products: {len(df_id)}\")\n","print(f\"Total chunks: {num_chunks}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"wHS_TApdFTf9","executionInfo":{"status":"ok","timestamp":1778792117685,"user_tz":-420,"elapsed":11,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}},"outputId":"f90790f4-9c82-46df-e15f-f5506f005b13"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Saved 20 products to data/product_id_chunks/product_ids_part_001.csv\n","\n","Done. Total products: 20\n","Total chunks: 1\n"]}]},{"cell_type":"code","source":["\n","# CONFIG\n","PRODUCT_ID_INPUT_PATH = \"data/tiki_pt_phukienchamsocxe.csv\"\n","REVIEW_OUTPUT_PATH = \"data/tiki_pt_review_phukienchamsocxe.csv\"\n","\n","REVIEW_API_URL = \"https://tiki.vn/api/v2/reviews\"\n","REVIEW_LIMIT = 5\n","\n","\n","# LOAD SECRETS\n","def load_secrets(group_name):\n","    \"\"\"\n","    Load optional cookies/tokens from secrets.json.\n","    Do NOT commit secrets.json to GitHub.\n","    \"\"\"\n","    secrets_path = Path(\"secrets.json\")\n","\n","    if not secrets_path.exists():\n","        return {}\n","\n","    with open(secrets_path, \"r\", encoding=\"utf-8\") as f:\n","        secrets = json.load(f)\n","\n","    return secrets.get(group_name, {})\n","\n","\n","review_secrets = load_secrets(\"review_crawler\")\n","\n","cookies = review_secrets.get(\"cookies\", {})\n","x_guest_token = review_secrets.get(\"x_guest_token\", \"\")\n","referer = review_secrets.get(\"referer\", \"https://tiki.vn/\")\n","extra_params = review_secrets.get(\"extra_params\", {})\n","\n","\n","# HEADERS AND PARAMS\n","headers = {\n","    \"User-Agent\": (\n","        \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) \"\n","        \"AppleWebKit/537.36 (KHTML, like Gecko) \"\n","        \"Chrome/143.0.0.0 Safari/537.36\"\n","    ),\n","    \"Accept\": \"application/json, text/plain, */*\",\n","    \"Accept-Language\": \"en-US,en;q=0.9,vi-VN;q=0.8,vi;q=0.7\",\n","    \"Referer\": referer,\n","    \"Connection\": \"keep-alive\",\n","}\n","\n","if x_guest_token:\n","    headers[\"x-guest-token\"] = x_guest_token\n","\n","\n","params = {\n","    \"limit\": REVIEW_LIMIT,\n","    \"include\": \"comments,contribute_info,attribute_vote_summary\",\n","    \"sort\": \"score|desc,id|desc,stars|all\",\n","    \"page\": 1,\n","    \"seller_id\": 9711,\n","    \"spid\": 275743198\n","}\n","\n","# Optional parameters from the original local script, if needed.\n","# Example: spid, product_id, seller_id.\n","for key, value in extra_params.items():\n","    if value not in (\"\", None):\n","        params[key] = value\n","\n","\n","# REVIEW PARSER\n","def comment_parser(review_json):\n","    d = {}\n","\n","    # attributes\n","    d[\"attributes\"] = review_json.get(\"attributes\")\n","\n","    # content\n","    d[\"content\"] = review_json.get(\"content\")\n","\n","    # created_by\n","    created_by = review_json.get(\"created_by\") or {}\n","\n","    d[\"customer_id\"] = created_by.get(\"id\")\n","    d[\"customer_full_name\"] = created_by.get(\"full_name\")\n","\n","    # contribute_info\n","    contribute_info = created_by.get(\"contribute_info\") or {}\n","\n","    d[\"avatar\"] = contribute_info.get(\"avatar\")\n","\n","    summary = contribute_info.get(\"summary\") or {}\n","\n","    d[\"customer_joined_time\"] = summary.get(\"joined_time\")\n","    d[\"customer_total_review\"] = summary.get(\"total_review\")\n","    d[\"customer_total_thank\"] = summary.get(\"total_thank\")\n","\n","    # delivery rating\n","    d[\"delivery_rating\"] = review_json.get(\"delivery_rating\")\n","\n","    # review id\n","    d[\"review_id\"] = review_json.get(\"id\")\n","\n","    # images\n","    images = review_json.get(\"images\") or []\n","    d[\"images\"] = images\n","\n","    # score\n","    d[\"new_score\"] = review_json.get(\"new_score\")\n","\n","    # product\n","    d[\"product_attributes\"] = review_json.get(\"product_attributes\")\n","\n","    # rating\n","    d[\"rating\"] = review_json.get(\"rating\")\n","    d[\"score\"] = review_json.get(\"score\")\n","\n","    # seller\n","    seller = review_json.get(\"seller\") or {}\n","\n","    d[\"seller_id\"] = seller.get(\"id\")\n","    d[\"seller_name\"] = seller.get(\"name\")\n","\n","    # suggestions\n","    d[\"suggestions\"] = review_json.get(\"suggestions\")\n","\n","    # thank\n","    d[\"thank_count\"] = review_json.get(\"thank_count\")\n","\n","    # timeline\n","    timeline = review_json.get(\"timeline\") or {}\n","\n","    d[\"review_created_date\"] = timeline.get(\"review_created_date\")\n","    d[\"delivery_date\"] = timeline.get(\"delivery_date\")\n","    d[\"explain\"] = timeline.get(\"explain\")\n","\n","    # vote_attributes\n","    vote_attributes = review_json.get(\"vote_attributes\") or {}\n","\n","    agree = vote_attributes.get(\"agree\") or []\n","    d[\"vote_agree\"] = agree\n","\n","    # derived features\n","    d[\"content_length\"] = len(review_json.get(\"content\") or \"\")\n","    d[\"num_images\"] = len(images)\n","    d[\"num_vote_agree\"] = len(agree)\n","\n","    return d\n","\n","\n","# CRAWL REVIEWS\n","\n","df_id = pd.read_csv(PRODUCT_ID_INPUT_PATH, encoding=\"utf-8-sig\")\n","products = df_id[[\"product_id\", \"name\"]].values.tolist()\n","\n","print(f\"Loaded {len(products)} products from {PRODUCT_ID_INPUT_PATH}\")\n","print(f\"Review output will be saved to {REVIEW_OUTPUT_PATH}\")\n","result = []\n","\n","for pid, pname in tqdm(products, total=len(products), desc=\"Crawling reviews\"):\n","    params[\"product_id\"] = pid\n","\n","    print(f\"Crawl comment for product {pid}\")\n","\n","    page = 1\n","\n","    while True:\n","        params[\"page\"] = page\n","\n","        response = requests.get(\n","            REVIEW_API_URL,\n","            headers=headers,\n","            params=params,\n","            cookies=cookies,\n","            timeout=20\n","        )\n","\n","        if response.status_code != 200:\n","            print(\"Request error:\", response.status_code)\n","            break\n","\n","        data = response.json().get(\"data\", [])\n","\n","        if len(data) == 0:\n","            break\n","\n","        for comment in data:\n","            d = comment_parser(comment)\n","            d[\"product_id\"] = pid\n","            d[\"name\"] = pname\n","            result.append(d)\n","\n","        print(f\"product {pid} page {page} -> {len(data)} reviews\")\n","\n","        page += 1\n","\n","        time.sleep(random.uniform(1, 3))\n","\n","\n","# SAVE REVIEWS\n","df_comment = pd.DataFrame(result)\n","\n","if not df_comment.empty:\n","    cols = df_comment.columns.tolist()\n","    cols = [\"product_id\", \"name\"] + [c for c in cols if c not in [\"product_id\", \"name\"]]\n","    df_comment = df_comment[cols]\n","\n","Path(\"data\").mkdir(exist_ok=True)\n","\n","df_comment.to_csv(\n","    REVIEW_OUTPUT_PATH,\n","    index=False,\n","    encoding=\"utf-8-sig\"\n",")\n","\n","print(f\"Saved {len(df_comment)} reviews to {REVIEW_OUTPUT_PATH}\")"],"metadata":{"id":"ixu5UhJ39DFZ","executionInfo":{"status":"ok","timestamp":1778793431946,"user_tz":-420,"elapsed":15708,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"e2c43b0c-b1f9-409a-9eb5-e74cf414c491"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Loaded 20 products from data/tiki_pt_phukienchamsocxe.csv\n","Review output will be saved to data/tiki_pt_review