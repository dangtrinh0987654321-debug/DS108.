ad_csv(path, dtype=str, low_memory=False)\n","            _print_stat(f\"  Loaded {path.name}\", f\"{len(df_chunk)} rows\")\n","            logger.info(\"Loaded %s (%d rows × %d cols).\", path, *df_chunk.shape)\n","            dfs.append(df_chunk)\n","        raw = pd.concat(dfs, ignore_index=True)\n","        _print_stat(\"Total combined rows\", len(raw))\n","        logger.info(\"Combined: %d rows × %d columns.\", *raw.shape)\n","        return raw"]},{"cell_type":"markdown","metadata":{"id":"nBZYe6ZcOMz8"},"source":["# **Chạy pipeline**"]},{"cell_type":"code","execution_count":11,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"tcL8dYS3OM_R","outputId":"b149fc94-4946-4544-d72e-e4a9a71b9bcb","executionInfo":{"status":"ok","timestamp":1779903730296,"user_tz":-420,"elapsed":142312,"user":{"displayName":"Tuan Pham","userId":"13028499005238298194"}}},"outputs":[{"output_type":"stream","name":"stdout","text":["\n","============================================================\n","  STEP: Loading raw data files\n","============================================================\n"]},{"output_type":"stream","name":"stderr","text":["WARNING:tiki_pipeline:Cột quan trọng 'customer_total_thank' không tồn tại — sẽ bỏ qua.\n"]},{"output_type":"stream","name":"stdout","text":["  [STAT]   Loaded data2.1.csv: 719451 rows\n","  [STAT] Total combined rows: 719451\n","\n","============================================================\n","  STEP: Phase 0 — Schema Validation\n","============================================================\n","  [STAT] Total columns: 18\n","  [STAT] Total rows: 719451\n","  [OK] Schema validation passed.\n","\n","============================================================\n","  STEP: Phase A — Row-wise Cleaning\n","============================================================\n","  [STAT] Rows at start: 719451\n","  [OK] Remove embedded headers\n"]},{"output_type":"stream","name":"stderr","text":["WARNING:tiki_pipeline:Critical ID 'customer_